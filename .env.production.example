# ============================================================
# The Wired V1 — Production Environment Variables
# Copy to .env and fill in all values marked with <...>
# ============================================================

# === Secrets (generate with: openssl rand -base64 32) ===
POSTGRES_PASSWORD=<generate-strong-password>
MEILI_MASTER_KEY=<generate-strong-key>
LIVEKIT_API_SECRET=<generate-strong-secret>

# Relay signing key (generate with: openssl rand -hex 32)
RELAY_SECRET_KEY=<generate-hex-key>

# === Environment ===
NODE_ENV=production
RUST_ENV=production
MEILI_ENV=production

# === Domain & CORS ===
# Comma-separated origins allowed by CORS
ALLOWED_ORIGINS=https://thewired.app,tauri://localhost,http://localhost
PUBLIC_URL=https://api.thewired.app

# === Database ===
POSTGRES_USER=thewired
POSTGRES_DB=thewired

# === Ports (exposed to host — remove in production if behind Caddy proxy) ===
# POSTGRES_PORT=5432
# REDIS_PORT=6379
# RELAY_PORT=7777
# BACKEND_PORT=3002
# GATEWAY_PORT=9080

# === Relay ===
RELAY_NAME=The Wired Relay
RUST_LOG=info,thewired_relay=info

# === Admin ===
ADMIN_PUBKEYS=<comma-separated-hex-pubkeys>

# === Push Notifications (generate with: npx web-push generate-vapid-keys) ===
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@thewired.app

# === LiveKit ===
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_API_KEY=devkey
# Set to the VPS public IP so WebRTC clients can reach the SFU
LIVEKIT_NODE_IP=<vps-public-ip>

# === Optional ===
GIF_API_KEY=
LOG_LEVEL=info
