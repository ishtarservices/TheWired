DATABASE_URL=postgres://thewired:thewired@localhost:5432/thewired
REDIS_URL=redis://localhost:6380
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=thewired_dev_key
RELAY_URL=ws://localhost:7777
PORT=3002
LOG_LEVEL=debug
GIF_API_KEY=
GIF_CLIENT_KEY=thewired_v1
BLOB_DIR=blobs
MAX_BLOB_SIZE=104857600

# LiveKit SFU — needed for voice channels and DM call SFU fallback.
# Local dev: `livekit-server --dev` (listens on :7880, creds devkey/secret).
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Cloudflare — provisions per-user *named* tunnels for self-hosted relays
# (Decentralized Spaces M7, POST /relays/tunnel/provision). Leave blank to
# disable named tunnels (clients fall back to zero-config quick tunnels).
# Token scope: Account › Cloudflare Tunnel:Edit + Zone › DNS:Edit on the tunnel
# zone. Backend-only — never sent to clients.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
# DNS zone for per-user relay subdomains (<id>.relay.thewired.app). Must be a
# hostname inside CLOUDFLARE_ZONE_ID.
TUNNEL_HOSTNAME_ZONE=relay.thewired.app
