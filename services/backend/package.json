{
  "name": "@thewired/backend",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^9.1.0",
    "@livekit/protocol": "^1.45.0",
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^1.8.0",
    "@thewired/shared-types": "workspace:*",
    "drizzle-orm": "^0.38.4",
    "fastify": "^5.8.4",
    "ioredis": "^5.4.2",
    "livekit-server-sdk": "^2.15.0",
    "meilisearch": "^0.46.0",
    "nostr-tools": "^2.23.1",
    "pino": "^9.6.0",
    "postgres": "^3.4.5",
    "web-push": "^3.6.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^4.1.4",
    "drizzle-kit": "^0.30.4",
    "ioredis-mock": "^8.13.1",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
