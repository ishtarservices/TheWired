---
import DownloadButton from './DownloadButton.tsx';
---

<section id="download" class="relative py-32 overflow-hidden section-panel bg-spiderweb-dense">
  <!-- Background -->
  <div class="absolute inset-0 bg-cyber-void" />
  <div class="absolute inset-0 bg-grid-cyber opacity-15" />

  <!-- Subtle ambient -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full blur-[200px] opacity-20"
    style="background: radial-gradient(circle, #60706015, #78587010, transparent);"
  />

  <div class="relative mx-auto max-w-6xl px-6">
    <div class="flex flex-col lg:flex-row items-center gap-8 lg:gap-12">

      <!-- Character — left -->
      <div class="hidden lg:flex flex-shrink-0 items-end justify-center relative w-[280px]">
        <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[200px] h-[200px] rounded-full blur-[80px]"
          style="background: radial-gradient(circle, #60706030, transparent);"
        />
        <img
          src="/characters/accent-guy.png"
          alt=""
          class="relative w-full h-auto animate-float-slow"
          style="filter: drop-shadow(0 0 25px #60706038) drop-shadow(0 0 50px #78587028) drop-shadow(0 0 90px #60706018);"
          loading="lazy"
        />
      </div>

      <!-- CTA card -->
      <div class="flex-1 relative">
        <!-- Outer border -->
        <div class="absolute -inset-[1px] rounded-lg"
          style="background: linear-gradient(135deg, #38403820, transparent 40%, transparent 60%, #221A2C20); border-radius: 8px;"
        />

        <div class="relative card-cyber rounded-lg p-10 sm:p-14 text-center space-y-8">
          <!-- HUD corners -->
          <div class="absolute top-2 left-2 w-4 h-4 border-t-2 border-l-2 rounded-tl-sm" style="border-color: #384038;" />
          <div class="absolute top-2 right-2 w-4 h-4 border-t-2 border-r-2 rounded-tr-sm" style="border-color: #384038;" />
          <div class="absolute bottom-2 left-2 w-4 h-4 border-b-2 border-l-2 rounded-bl-sm" style="border-color: #221A2C;" />
          <div class="absolute bottom-2 right-2 w-4 h-4 border-b-2 border-r-2 rounded-br-sm" style="border-color: #221A2C;" />

          <div class="section-label">
            <span class="w-1.5 h-1.5 rounded-full animate-pulse-glow" style="background: #607060;"></span>
            Ready to Deploy
          </div>

          <h2 class="text-3xl sm:text-4xl font-bold tracking-tight" style="color: #E4DDE8;">
            Ready to Enter?
          </h2>
          <p class="text-lg max-w-xl mx-auto leading-relaxed" style="color: #9A8FA8;">
            Download The Wired for your platform. Free, open source, and always will be.
          </p>

          <DownloadButton client:load />

          <p class="text-sm font-mono" style="color: #6B6078;">
            macOS 13+ &middot; Windows 10+ &middot; Linux
          </p>
        </div>
      </div>

      <!-- Character — right -->
      <div class="hidden xl:flex flex-shrink-0 items-end justify-center relative w-[200px]">
        <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[150px] h-[150px] rounded-full blur-[60px]"
          style="background: radial-gradient(circle, #78587028, transparent);"
        />
        <img
          src="/characters/hero-girl-alt.png"
          alt=""
          class="relative w-full h-auto animate-float-slow"
          style="animation-delay: -3s; filter: drop-shadow(0 0 20px #78587030) drop-shadow(0 0 60px #78587018);"
          loading="lazy"
        />
      </div>

    </div>
  </div>
</section>
