---
const currentYear = new Date().getFullYear();
---

<footer class="relative border-t py-16" style="border-color: hsl(185 100% 55% / 0.06);">
  <!-- Top border glow -->
  <div class="absolute top-0 left-0 right-0 h-px"
    style="background: linear-gradient(90deg, transparent, hsl(185 100% 55% / 0.15), hsl(265 100% 70% / 0.1), transparent);"
  />

  <div class="mx-auto max-w-7xl px-6">
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-12">
      <!-- Brand -->
      <div class="space-y-4">
        <div class="flex items-center gap-3">
          <img src="/logo.png" alt="The Wired" class="w-8 h-8 rounded-lg" />
          <span class="font-bold text-lg">
            <span class="text-gradient-neon">The Wired</span>
          </span>
        </div>
        <p class="text-muted text-sm leading-relaxed">
          Decentralized media platform built on Nostr.
          Own your data. Own your identity.
        </p>
        <!-- Mini cyber decoration -->
        <div class="w-12 h-px mt-4" style="background: linear-gradient(90deg, hsl(185 100% 55% / 0.3), transparent);" />
      </div>

      <!-- Product -->
      <div class="space-y-4">
        <h4 class="text-xs font-semibold uppercase tracking-[0.15em]" style="color: hsl(185 100% 55% / 0.6);">Product</h4>
        <ul class="space-y-2.5">
          <li><a href="#download" class="text-muted hover:text-primary transition-colors text-sm">Download</a></li>
          <li><a href="#features" class="text-muted hover:text-primary transition-colors text-sm">Features</a></li>
          <li><a href="#showcase" class="text-muted hover:text-primary transition-colors text-sm">Showcase</a></li>
        </ul>
      </div>

      <!-- Protocol -->
      <div class="space-y-4">
        <h4 class="text-xs font-semibold uppercase tracking-[0.15em]" style="color: hsl(265 100% 70% / 0.6);">Protocol</h4>
        <ul class="space-y-2.5">
          <li><a href="https://nostr.org/" target="_blank" rel="noopener noreferrer" class="text-muted hover:text-primary transition-colors text-sm">What is Nostr?</a></li>
          <li><a href="https://nostr-nips.com/" target="_blank" rel="noopener noreferrer" class="text-muted hover:text-primary transition-colors text-sm">NIPs (Protocol Specs)</a></li>
          <li><a href="https://relay.thewired.app" target="_blank" rel="noopener noreferrer" class="text-muted hover:text-primary transition-colors text-sm">Our Relay</a></li>
        </ul>
      </div>

      <!-- Community -->
      <div class="space-y-4">
        <h4 class="text-xs font-semibold uppercase tracking-[0.15em]" style="color: hsl(310 100% 65% / 0.6);">Community</h4>
        <ul class="space-y-2.5">
          <li>
            <a href="https://github.com/IshtarServices/TheWired" target="_blank" rel="noopener noreferrer" class="text-muted hover:text-primary transition-colors text-sm inline-flex items-center gap-1.5">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              GitHub
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4" style="border-top: 1px solid hsl(185 100% 55% / 0.04);">
      <p class="text-faint text-sm font-mono text-xs">
        &copy; {currentYear} The Wired. All rights reserved.
      </p>
      <div class="flex items-center gap-2 text-faint text-sm">
        <span class="text-xs">Built on</span>
        <span class="text-gradient-neon font-semibold text-xs">Nostr</span>
        <span class="text-xs mx-1" style="color: hsl(185 100% 55% / 0.15);">//</span>
        <span class="text-xs font-mono" style="color: hsl(185 100% 55% / 0.3);">v0.1.0</span>
      </div>
    </div>
  </div>
</footer>
