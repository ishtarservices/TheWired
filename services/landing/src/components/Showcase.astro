---
import ShowcaseSlider from './ShowcaseSlider.tsx';
---

<section id="showcase" class="relative py-24 overflow-hidden section-panel" style="border-top: 1px solid #221A2C;">
  <div class="relative mx-auto max-w-7xl px-6">
    <!-- Section header + nav arrows row -->
    <div class="flex items-end justify-between mb-10">
      <div class="space-y-3">
        <div class="section-label">
          Interface Preview
        </div>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight" style="color: #E4DDE8;">
          See It In Action
        </h2>
        <p class="text-lg max-w-xl" style="color: #9A8FA8;">
          Explore the features that make The Wired a new kind of social media platform.
        </p>
      </div>

      <!-- Navigation arrows -->
      <div class="hidden sm:flex items-center gap-2" id="showcase-nav">
        <button
          data-dir="prev"
          class="w-10 h-10 rounded-full border flex items-center justify-center transition-colors"
          style="border-color: #221A2C; color: #9A8FA8;"
          aria-label="Scroll left"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <polyline points="15,18 9,12 15,6" />
          </svg>
        </button>
        <button
          data-dir="next"
          class="w-10 h-10 rounded-full border flex items-center justify-center transition-colors"
          style="border-color: #221A2C; color: #9A8FA8;"
          aria-label="Scroll right"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <polyline points="9,6 15,12 9,18" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Slider -->
  <ShowcaseSlider client:visible />

  <!-- Bottom edge -->
  <div class="absolute bottom-0 left-0 right-0 h-px" style="background: linear-gradient(90deg, transparent, #221A2C, transparent);" />
</section>

<script>
  const nav = document.getElementById('showcase-nav');
  const track = document.getElementById('showcase-track');
  if (nav && track) {
    nav.querySelectorAll('button').forEach(btn => {
      btn.addEventListener('click', () => {
        const dir = btn.getAttribute('data-dir');
        const cardWidth = track.querySelector('.showcase-card')?.clientWidth ?? 400;
        const gap = 20;
        const scrollAmount = cardWidth + gap;
        track.scrollBy({
          left: dir === 'next' ? scrollAmount : -scrollAmount,
          behavior: 'smooth',
        });
      });
    });
  }
</script>
