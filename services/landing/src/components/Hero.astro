---
import HeroVisual from './HeroVisual.tsx';
---

<section class="relative min-h-screen flex items-center overflow-hidden pt-20">
  <!-- Deep void background with cyber gradients -->
  <div class="absolute inset-0 bg-cyber-void" />

  <!-- Perspective grid floor -->
  <div class="absolute inset-0 bg-grid-perspective opacity-60" />

  <!-- Animated scan line -->
  <div class="absolute left-0 right-0 h-[2px] animate-scan-line z-[2] pointer-events-none"
    style="background: linear-gradient(90deg, transparent, hsl(185 100% 55% / 0.15), hsl(185 100% 55% / 0.3), hsl(185 100% 55% / 0.15), transparent);"
  />

  <!-- Gradient orbs — deeper, more dramatic -->
  <div class="absolute top-1/4 -left-[10%] w-[600px] h-[600px] rounded-full blur-[150px] animate-float opacity-60"
    style="background: radial-gradient(circle, hsl(185 100% 55% / 0.08), transparent 70%);"
  />
  <div class="absolute bottom-1/4 -right-[10%] w-[500px] h-[500px] rounded-full blur-[130px] animate-float opacity-50"
    style="animation-delay: -3s; background: radial-gradient(circle, hsl(310 100% 65% / 0.06), transparent 70%);"
  />
  <div class="absolute top-[60%] left-[40%] w-[400px] h-[400px] rounded-full blur-[120px] animate-float opacity-40"
    style="animation-delay: -5s; background: radial-gradient(circle, hsl(265 100% 70% / 0.05), transparent 70%);"
  />

  <!-- Scanlines overlay -->
  <div class="absolute inset-0 scanlines pointer-events-none" />

  <div class="relative z-10 mx-auto max-w-7xl px-6 w-full flex flex-col lg:flex-row items-center lg:items-end gap-8 lg:gap-0">
    <!-- Text content — left side -->
    <div class="flex-1 text-center lg:text-left space-y-8 animate-fade-in-up pb-20 lg:pb-32">
      <!-- HUD label -->
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-medium tracking-widest uppercase"
        style="background: hsl(185 100% 55% / 0.06); border: 1px solid hsl(185 100% 55% / 0.15); color: hsl(185 100% 55%);">
        <span class="w-1.5 h-1.5 rounded-full animate-pulse-glow" style="background: hsl(185 100% 55%);"></span>
        Protocol: Nostr // Status: Online
      </div>

      <h1 class="text-5xl sm:text-6xl lg:text-7xl xl:text-8xl font-bold tracking-tighter leading-[1.05]">
        <span class="text-heading">Enter</span>
        <br />
        <span class="text-gradient-cyber glow-text-cyan">The Wired</span>
      </h1>

      <p class="text-lg sm:text-xl text-soft max-w-xl mx-auto lg:mx-0 leading-relaxed">
        A decentralized media platform where you own your data, your identity,
        and your community. Built on <span class="text-primary">Nostr</span> — no central servers, no gatekeepers.
      </p>

      <div class="flex flex-col sm:flex-row items-center gap-4 justify-center lg:justify-start">
        <a
          href="#download"
          class="group relative inline-flex items-center gap-3 px-8 py-3.5 rounded-xl font-semibold text-lg transition-all press-effect overflow-hidden"
          style="background: linear-gradient(135deg, hsl(185 100% 55%), hsl(265 100% 70%)); color: hsl(230 20% 5%);"
        >
          <span class="relative z-10 flex items-center gap-3">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
              <polyline points="7,10 12,15 17,10" />
              <line x1="12" y1="15" x2="12" y2="3" />
            </svg>
            Download Now
          </span>
          <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity"
            style="background: linear-gradient(135deg, hsl(185 80% 65%), hsl(310 100% 65%));"
          />
          <!-- Shimmer effect -->
          <div class="absolute inset-0 -translate-x-full group-hover:translate-x-full transition-transform duration-700"
            style="background: linear-gradient(90deg, transparent, hsl(0 0% 100% / 0.15), transparent);"
          />
        </a>

        <a
          href="https://github.com/IshtarServices/TheWired"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3.5 rounded-xl border text-soft hover:text-primary hover:border-primary/30 transition-all text-base font-medium hover-glow-cyan"
          style="border-color: hsl(185 100% 55% / 0.1);"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          View on GitHub
        </a>
      </div>

      <!-- Tech badges -->
      <div class="flex items-center gap-3 justify-center lg:justify-start pt-2">
        <span class="text-faint text-xs uppercase tracking-wider">Built with</span>
        <div class="flex items-center gap-2">
          <span class="px-2.5 py-1 rounded text-[11px] font-medium text-muted" style="background: hsl(185 100% 55% / 0.06); border: 1px solid hsl(185 100% 55% / 0.1);">Nostr</span>
          <span class="px-2.5 py-1 rounded text-[11px] font-medium text-muted" style="background: hsl(265 100% 70% / 0.06); border: 1px solid hsl(265 100% 70% / 0.1);">Tauri</span>
          <span class="px-2.5 py-1 rounded text-[11px] font-medium text-muted" style="background: hsl(310 100% 65% / 0.06); border: 1px solid hsl(310 100% 65% / 0.1);">Rust</span>
        </div>
      </div>
    </div>

    <!-- Character visual — right side -->
    <div class="flex-1 relative w-full max-w-xl lg:max-w-lg xl:max-w-xl min-h-[400px] lg:min-h-[600px]" style="animation: fade-in-up 0.6s ease-out 0.2s both;">
      <HeroVisual client:load />
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 z-20">
    <span class="text-faint text-[10px] uppercase tracking-[0.2em] animate-pulse-glow">Scroll</span>
    <div class="w-5 h-8 rounded-full border flex items-start justify-center p-1.5"
      style="border-color: hsl(185 100% 55% / 0.2);">
      <div class="w-1 h-1.5 rounded-full animate-float" style="background: hsl(185 100% 55% / 0.5);"></div>
    </div>
  </div>
</section>
