---
---

<section id="about" class="relative py-32 overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 bg-cyber-void opacity-30" />

  <div class="relative mx-auto max-w-7xl px-6">
    <div class="grid lg:grid-cols-[1fr_auto_1fr] gap-10 lg:gap-6 items-center">
      <!-- Text — left -->
      <div class="space-y-8">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-[10px] font-medium tracking-[0.2em] uppercase"
          style="background: hsl(265 100% 70% / 0.06); border: 1px solid hsl(265 100% 70% / 0.1); color: hsl(265 100% 70% / 0.6);">
          Philosophy
        </div>

        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight leading-tight">
          <span class="text-heading">Own Your</span>
          <span class="text-primary"> Digital Space</span>
        </h2>

        <div class="space-y-6 text-soft text-lg leading-relaxed">
          <p>
            The Wired is built on <strong class="text-primary font-semibold">Nostr</strong> — an open,
            censorship-resistant protocol. Your identity is a cryptographic key pair that you control.
            No email signups, no phone numbers, no central authority.
          </p>
          <p>
            Your content lives across a network of relays, not locked inside
            a single company's servers. Switch apps, switch relays — your data
            follows you because <strong class="text-heading font-semibold">you own it</strong>.
          </p>
          <p>
            We believe social media should serve its users, not exploit them.
            No ads, no algorithms manipulating your feed, no data harvesting.
            Just your community, your way.
          </p>
        </div>
      </div>

      <!-- Character — center, clearly visible -->
      <div class="hidden lg:flex items-end justify-center relative">
        <!-- Glow behind character -->
        <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[250px] h-[250px] rounded-full blur-[80px]"
          style="background: radial-gradient(circle, hsl(185 100% 55% / 0.1), hsl(265 100% 70% / 0.05), transparent);"
        />
        <img
          src="/characters/cyber-girl.png"
          alt=""
          class="relative w-[240px] h-auto"
          style="filter: drop-shadow(0 0 30px hsl(185 100% 55% / 0.15)) drop-shadow(0 0 60px hsl(265 100% 70% / 0.08));"
          loading="lazy"
        />
      </div>

      <!-- Principle cards — right -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-1 xl:grid-cols-2 gap-4">
        <div class="card-cyber rounded-xl p-6 space-y-3 hover-lift group">
          <div class="w-12 h-12 rounded-lg flex items-center justify-center transition-colors"
            style="background: hsl(185 100% 55% / 0.08);">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="color: hsl(185 100% 55%);">
              <circle cx="12" cy="12" r="3" />
              <circle cx="4" cy="6" r="2" />
              <circle cx="20" cy="6" r="2" />
              <circle cx="4" cy="18" r="2" />
              <circle cx="20" cy="18" r="2" />
              <line x1="6" y1="6.5" x2="9.5" y2="10" />
              <line x1="18" y1="6.5" x2="14.5" y2="10" />
              <line x1="6" y1="17.5" x2="9.5" y2="14" />
              <line x1="18" y1="17.5" x2="14.5" y2="14" />
            </svg>
          </div>
          <h3 class="text-heading font-semibold text-base">Decentralized</h3>
          <p class="text-muted text-sm leading-relaxed">
            No single point of failure. Your content is distributed across relays you choose.
          </p>
        </div>

        <div class="card-cyber rounded-xl p-6 space-y-3 hover-lift group">
          <div class="w-12 h-12 rounded-lg flex items-center justify-center"
            style="background: hsl(310 100% 65% / 0.08);">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="color: hsl(310 100% 65%);">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
              <path d="M7 11V7a5 5 0 0 1 10 0v4" />
              <circle cx="12" cy="16" r="1" />
            </svg>
          </div>
          <h3 class="text-heading font-semibold text-base">Encrypted</h3>
          <p class="text-muted text-sm leading-relaxed">
            Cryptographic key pairs for identity. Private messages with end-to-end encryption.
          </p>
        </div>

        <div class="card-cyber rounded-xl p-6 space-y-3 hover-lift group">
          <div class="w-12 h-12 rounded-lg flex items-center justify-center"
            style="background: hsl(265 100% 70% / 0.08);">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="color: hsl(265 100% 70%);">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
              <polyline points="9,12 11,14 15,10" />
            </svg>
          </div>
          <h3 class="text-heading font-semibold text-base">Sovereign</h3>
          <p class="text-muted text-sm leading-relaxed">
            You own your keys, your data, your identity. No account can be banned or deleted.
          </p>
        </div>

        <div class="card-cyber rounded-xl p-6 space-y-3 hover-lift group">
          <div class="w-12 h-12 rounded-lg flex items-center justify-center"
            style="background: hsl(185 100% 55% / 0.08);">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="color: hsl(185 100% 55%);">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
              <polyline points="15,3 21,3 21,9" />
              <line x1="10" y1="14" x2="21" y2="3" />
            </svg>
          </div>
          <h3 class="text-heading font-semibold text-base">Open Source</h3>
          <p class="text-muted text-sm leading-relaxed">
            Fully open source. Inspect the code, contribute, or fork it. Transparency by design.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
