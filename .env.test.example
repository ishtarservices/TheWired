# Test user nsec keys for the test suite.
# Copy this to .env.test and fill in your own test keys.
# Generate keys with: node -e "const {generateSecretKey}=require('nostr-tools');const {nip19}=require('nostr-tools');console.log(nip19.nsecEncode(generateSecretKey()))"
# Or use any Nostr key generator.
#
# If .env.test is missing, the test suite auto-generates ephemeral keys per run.

TEST_NSEC_LUNA_VEGA=
TEST_NSEC_MARCUS_COLE=
TEST_NSEC_SAGE_NAKAMURA=
TEST_NSEC_ZARA_WILLIAMS=
TEST_NSEC_DECKARD_STONE=
TEST_NSEC_NIA_OKAFOR=
TEST_NSEC_RIVER_CHEN=
TEST_NSEC_FELIX_MOREAU=
TEST_NSEC_ARIA_BLACKWOOD=
TEST_NSEC_JAYDEE=
