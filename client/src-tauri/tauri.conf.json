{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "The Wired",
  "version": "0.3.0",
  "identifier": "app.thewired.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm --filter @thewired/client dev",
    "beforeBuildCommand": "pnpm --filter @thewired/client build"
  },
  "app": {
    "windows": [
      {
        "title": "The Wired",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' https: blob: data:; media-src 'self' https: blob:; connect-src 'self' https://*.thewired.app wss: ws: https: http://localhost:*; worker-src 'self' blob:"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ishtarservices/TheWired/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJBQjY2RkNFRTdEQkFCNDcKUldSSHE5dm56bSsydWgrR0t0dWF1U3RXa3VxVnFkU2R3eWtwMWU0R3FvNXhpc3ovOW81WERQbWgK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist",
      "minimumSystemVersion": "13.0"
    }
  }
}
